# =============================================================================
# Enterprise Customer Support Agent — Environment Variables
# Copy this file to .env and fill in all values before running the project.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Found in: Supabase dashboard → Project Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key has admin privileges — only used server-side (FastAPI).
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Anthropic (Claude — LLM and query rewriting via Haiku)
# Found in: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI (embeddings only — text-embedding-3-small)
# Found in: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Linear
# API key: https://linear.app/settings/api
# Team ID: visible in the URL when viewing your team workspace
# -----------------------------------------------------------------------------
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# -----------------------------------------------------------------------------
# Slack
# Create an Incoming Webhook: https://api.slack.com/messaging/webhooks
# Points to your support team channel.
# Leave blank to disable Slack notifications (escalation still works).
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Resend (email notifications)
# API key: https://resend.com/api-keys
# FROM_EMAIL must be a verified domain in your Resend account.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@yourdomain.com
SUPPORT_TEAM_EMAIL=team@yourdomain.com

# -----------------------------------------------------------------------------
# Crisp (live chat handoff)
# Found in: Crisp dashboard → Settings → Website → API & SDKs
# Leave blank to disable Crisp handoff (escalation still works).
# -----------------------------------------------------------------------------
CRISP_WEBSITE_ID=
CRISP_IDENTIFIER=
CRISP_KEY=

# -----------------------------------------------------------------------------
# FastAPI backend
# -----------------------------------------------------------------------------
# "development" or "production" — controls CORS origins and debug logging
ENVIRONMENT=development
# Secret used to sign internal tokens if needed (generate with: openssl rand -hex 32)
SECRET_KEY=
# Comma-separated list of allowed CORS origins.
# Development default is http://localhost:3000.
# In production set this to your Vercel frontend URL, e.g.: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
# Optional: override the default LLM model (default: claude-haiku-4-5-20251001)
LLM_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Next.js frontend (NEXT_PUBLIC_ prefix = exposed to browser)
# NEXT_PUBLIC_SUPABASE_* must match the values above.
# NEXT_PUBLIC_API_URL = Railway URL in production, http://localhost:8000 in dev.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Demo admin account (optional — enables the "Login as Admin" button on the login page)
# Create an account in Supabase Auth and paste its credentials here.
# Lands on /admin/documents after login.
# NEXT_PUBLIC_ is intentional: these are demo-only credentials.
# Regular users sign up via the standard form — no demo shortcut needed.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=
